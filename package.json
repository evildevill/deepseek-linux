{
  "name": "deepseek-linux",
  "version": "1.0.2",
  "description": "A simple and efficient desktop client for DeepSeek.",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux snap",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evildevill/deepseek-linux.git"
  },
  "keywords": [
    "electron",
    "deepseek",
    "desktop",
    "linux"
  ],
  "author": "evildevill",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/evildevill/deepseek-linux/issues"
  },
  "homepage": "https://github.com/evildevill/deepseek-linux#readme",
  "dependencies": {
    "electron-context-menu": "^4.1.1"
  },
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "productName": "DeepSeek",
    "appId": "com.evildevill.deepseeklinux",
    "linux": {
      "target": "snap",
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
